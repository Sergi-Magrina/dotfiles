/*
 * GENERATED FILE — do not edit rofi/config.rasi by hand.
 * Source template: theme/templates/config.rasi.in
 * Palette:         theme/palettes/<active>.env  (rendered by theme/gen.py)
 * rofi re-reads its theme on each launch, so a regenerated file applies to the
 * next rofi you open — no reload needed.
 */

configuration {
    modi:                "drun";
    show-icons:          true;
    icon-theme:          "Adwaita";
    drun-display-format: "{name}";
    /* Accent search glyph as the prompt (Nerd Font). */
    display-drun:        " ";
}

* {
    /* Palette — rendered from theme/palettes/<active>.env. */
    bg:            #{{background}};      /* near-black surface */
    bg-alpha:      #{{background}}cc;    /* ~80% opaque window background (cc = 204/255) */
    accent:        #{{accent}};          /* primary accent — text / interactive */
    accent-bright: #{{accent_bright}};   /* brighter accent — hover / active / selection */
    muted:         #{{muted}};           /* muted — inactive / disabled */
    transparent:   rgba(0, 0, 0, 0%);

    background-color: transparent;
    text-color:       @accent;
    font:             "JetBrainsMono Nerd Font 12";
}

window {
    transparency:     "real";
    location:         center;
    anchor:           center;
    width:            50%;
    background-color: @bg-alpha;
    border:           2px;
    border-color:     @accent;    /* accent border */
    border-radius:    10px;       /* matches Hyprland rounding */
    padding:          12px;
}

mainbox {
    background-color: transparent;
    children:         [ inputbar, listview ];
    spacing:          10px;
    padding:          8px;
}

inputbar {
    background-color: transparent;
    children:         [ prompt, entry ];
    spacing:          10px;
    padding:          8px;
    border:           0px 0px 2px 0px;   /* bottom rule under the search line */
    border-color:     @accent;
}

prompt {
    background-color: transparent;
    text-color:       @accent;    /* accent prompt glyph */
    vertical-align:   0.5;
}

entry {
    background-color:  transparent;
    text-color:        @accent;
    placeholder:       "Search apps";
    placeholder-color: @muted;
    cursor:            text;
    vertical-align:    0.5;
}

listview {
    background-color: transparent;
    lines:            4;
    columns:          1;
    spacing:          4px;
    scrollbar:        false;
    fixed-height:     false;
    cycle:            true;
}

element {
    spacing:          10px;
    padding:          6px;
    border-radius:    6px;
}

/*
 * State-qualified selectors are REQUIRED here: rofi merges a built-in base
 * theme whose `element <row>.<state>` rules (e.g. selected.normal) outrank a
 * plain `element selected`, so without these the default light entries win.
 * Rows: normal / alternate / selected.  States: normal / urgent / active.
 */
element normal.normal,
element alternate.normal,
element normal.urgent,
element alternate.urgent,
element normal.active,
element alternate.active {
    background-color: transparent;
    text-color:       @accent;
}

element selected.normal,
element selected.urgent,
element selected.active {
    background-color: @accent-bright;   /* selection highlight */
    text-color:       @bg;              /* dark text for contrast on bright accent */
}

element-icon {
    background-color: transparent;
    size:             1.0em;
    vertical-align:   0.5;
}

element-text {
    background-color: transparent;
    text-color:       inherit;
    vertical-align:   0.5;
}
