# white-brown — a LIGHT theme: warm cream background with brown accents (the
# "white/brown" theme, the one light palette among the set). Same five slots +
# foot_alpha as the others. Because the background is light, `foreground` is a
# DARK espresso here so text stays readable — the mirror of the dark themes.
# `gen` renders every consumer; `set-theme white-brown` switches to it.
background=f2ebdf    # warm off-white / cream surface
accent=8a5a2b        # rich brown — primary text / interactive
accent_bright=b5742f # warmer/lighter brown — hover / active / selection
muted=b0a48e         # muted tan-gray — inactive / disabled
foreground=33261a    # dark espresso text — readable on the cream surface

# Non-colour per-theme knob: foot's background transparency (0.0–1.0).
foot_alpha=0.85
