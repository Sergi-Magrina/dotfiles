# purple-blue — dark navy background with a vivid blue accent (the "purple/blue"
# theme). One of the runtime-swappable palettes (phase 7b). Same five slots +
# foot_alpha as red-black; `gen` renders every consumer, colors.lua reads it for
# Hyprland's borders. Bare hex (no '#'); `set-theme purple-blue` switches to it.
background=141824    # near-black navy surface
accent=4c7fff        # vivid blue — primary text / interactive
accent_bright=7aa2ff # lighter blue — hover / active / selection
muted=555a6e         # muted blue-gray — inactive / disabled
foreground=e6e9f2    # plain text — inactive workspace numbers, terminal text

# Non-colour per-theme knob: foot's background transparency (0.0–1.0).
foot_alpha=0.85
