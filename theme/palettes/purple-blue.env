# purple-blue — navy-blue background with a royal-purple accent (the "blue/
# purple" theme). A 2-colour palette like the others: a dominant dark background
# (navy blue) plus one accent (purple) that drives all text/interactive elements
# and every outline — window/terminal/app borders are solid purple. accent_bright
# and muted are just shades of that accent for hover/inactive states.
# `set-theme purple-blue` switches to it; bare hex, no '#'.
background=141824    # navy-blue surface (the dominant colour)
accent=7c3aed        # royal purple — text / interactive / all outlines
accent_bright=9d6bf5 # lighter purple — hover / active / selection
muted=5b5470         # muted purple-gray — inactive / disabled
foreground=e6e9f2    # plain text — inactive workspace numbers, terminal text

# Non-colour per-theme knob: foot's background transparency (0.0–1.0).
foot_alpha=0.85
