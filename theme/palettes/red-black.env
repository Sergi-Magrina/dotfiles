# red-black — the default palette (roadmap step 1's black background / red accent).
#
# THE single source of truth for this theme's colours. `gen` reads this and
# renders every consumer (waybar, rofi, foot, and the volume scripts' colors.env);
# hypr/colors.lua reads it directly for Hyprland's borders. Change a colour here
# and re-run `gen` (or `set-theme red-black`) — never hand-edit the generated files.
#
# Values are BARE hex (no leading '#') so Hyprland's rgba(RRGGBBAA) helper in
# colors.lua can interpolate them directly; `gen` adds the '#' for CSS/rasi.
#
# Slots (same five every palette defines):
background=0d0d0d    # near-black surface
accent=c8102e        # primary text / interactive (was `red`)
accent_bright=e8384f # hover / active / selection (was `red_bright`)
muted=5a5a5a         # inactive / disabled (was `gray`)
foreground=ffffff    # plain text — inactive workspace numbers (was hardcoded, not in the old palette)

# Non-colour per-theme knob: foot's background transparency (0.0–1.0).
foot_alpha=0.85
